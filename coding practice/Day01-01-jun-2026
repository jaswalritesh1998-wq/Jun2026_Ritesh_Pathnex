Git Integration
Jenkins Pipeline — Checkout Git

pipeline {

agnet any //run on any available angent

stages {

stage('checkout')
     steps  {
            // clone this git repo from github
            // equivalent command:
            // git clone -b main on https /../.git
           git branch: 'main'
               url: 'url: 'https://github.com/Pathnex/sample-java-app.git''
stage('List Files') {
    steps {

        // sh executes a Linux shell command on the Jenkins agent
        // Equivalent command: ls -la (a is for all  dir ,hidden file)

        sh 'ls -la'
    }
}



GitLab CI — Checkout Git

stages:
  - checkout  # Pipeline stage

git-checkout:
  stage: checkout  # Job runs in checkout stage

  script:

    # Command: git clone <repository-url>
    # Purpose: Download the repository from GitHub
    - git clone https://github.com/Pathnex/sample-java-ap.git

    # Command: cd sample-java-app
    # Purpose: Change into the cloned repository directory
    - cd sample-java-app

    # Command: ls -la
    # Purpose: List all files and dir including hidden too
    - ls -la




